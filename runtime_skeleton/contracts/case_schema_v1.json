{
  "version": "case_schema_v1",
  "mode": "local_dry_shared_case_json",
  "description": "Shared case bridge between Telegram, Browser dashboard, future Server brain, and agent placeholders.",
  "required_fields": [
    "case_id",
    "route_id",
    "route_name",
    "case_namespace",
    "source_channel",
    "status",
    "created_at",
    "updated_at",
    "operator_inputs",
    "supplier_url",
    "product_name",
    "product_text",
    "photo_notes",
    "receipt_notes",
    "files_notes",
    "cost_price",
    "sell_price",
    "stock_qty",
    "shipping_notes",
    "ion_comments",
    "next_action",
    "approval_state",
    "assigned_agent",
    "agent_notes",
    "server_bridge_status",
    "report_refs",
    "checkpoint_refs",
    "history",
    "safety_locks"
  ],
  "source_channel_enum": [
    "telegram",
    "browser",
    "server",
    "import"
  ],
  "default_status": "draft_local_only",
  "default_approval_state": "approval_required_before_live_action",
  "default_server_bridge_status": "dry_not_sent",
  "field_types": {
    "case_id": "string",
    "route_id": "string",
    "route_name": "string",
    "case_namespace": "string",
    "source_channel": "enum",
    "status": "string",
    "created_at": "iso_datetime_string",
    "updated_at": "iso_datetime_string",
    "operator_inputs": "object",
    "supplier_url": "string",
    "product_name": "string",
    "product_text": "string",
    "photo_notes": "string",
    "receipt_notes": "string",
    "files_notes": "string",
    "cost_price": "string",
    "sell_price": "string",
    "stock_qty": "string",
    "shipping_notes": "string",
    "ion_comments": "string",
    "next_action": "string",
    "approval_state": "string",
    "assigned_agent": "string",
    "agent_notes": "string",
    "server_bridge_status": "string",
    "report_refs": "array",
    "checkpoint_refs": "array",
    "history": "array",
    "safety_locks": "object"
  },
  "safety_locks": {
    "no_live_telegram_patch": true,
    "no_server_write": true,
    "no_ebay_action": true,
    "no_delete": true,
    "approval_required_for_live": true
  }
}
